# ── Vercel KV (Redis) ─────────────────────────────────────────────────────────
# Get these from: Vercel Dashboard → Storage → KV → Connect
KV_URL=redis://your_kv_url_here
KV_REST_API_URL=https://your-kv-endpoint.vercel-storage.com
KV_REST_API_TOKEN=your_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string
